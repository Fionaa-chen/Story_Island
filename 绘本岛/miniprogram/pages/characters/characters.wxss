/* pages/characters/characters.wxss · 蜡笔绘本风 */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
}

/* ============ 书籍头部 · 蜡笔纹理 ============ */
.book-header {
  padding: 40rpx 32rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header-texture {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at 20% 30%, rgba(255, 255, 255, 0.10) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(255, 255, 255, 0.08) 0%, transparent 40%);
  pointer-events: none;
}

.header-content {
  display: flex;
  gap: 28rpx;
  align-items: flex-start;
  position: relative;
  z-index: 1;
}

.header-cover {
  width: 160rpx;
  height: 210rpx;
  border-radius: var(--radius-md);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.2);
  border: 3rpx solid rgba(255, 255, 255, 0.15);
  transform: rotate(-1deg);
}

.header-info {
  flex: 1;
  min-width: 0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.header-author {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* 头部装饰 */
.header-deco-wrap {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  z-index: 1;
}

.header-deco-star {
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
  animation: starTwinkle 3s ease-in-out infinite;
}

.header-deco-star.s2 {
  font-size: 20rpx;
  margin-left: 8rpx;
  animation-delay: 1.5s;
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.3); }
}

/* ============ 步骤指示器 · 蜡笔涂画风 ============ */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 32rpx 8rpx;
  gap: 0;
}

.step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #D9D0C4;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: 3rpx solid #D9D0C4;
  box-shadow: 2rpx 2rpx 0 rgba(60, 40, 20, 0.06);
}

.step.active {
  transform: scale(1.15);
  box-shadow: 0 3rpx 12rpx rgba(0, 0, 0, 0.15);
}

.step-num {
  font-size: 26rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #FFFFFF;
}

.step-line-wrap {
  width: 80rpx;
  padding: 0 6rpx;
}

.step-line {
  width: 100%;
  height: 4rpx;
  background: #D9D0C4;
  transition: all 0.3s ease;
  border-radius: 4rpx;
  /* 手绘虚线风格 */
  background-image: repeating-linear-gradient(
    90deg,
    #D9D0C4 0px,
    #D9D0C4 8px,
    transparent 8px,
    transparent 12px
  );
}

.step-line.active {
  background-image: none;
}

/* ============ 区域标题 · 蜡笔风 ============ */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  position: relative;
  flex-wrap: wrap;
}

.section-icon {
  font-size: 36rpx;
}

.section-text {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 32rpx;
  font-weight: 700;
}

.section-underline {
  width: 100%;
  height: 3rpx;
  opacity: 0.3;
  border-radius: 2rpx;
  margin-top: 4rpx;
}

/* 返回按钮 */
.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text-hint);
  padding: 8rpx 16rpx;
  background: rgba(139, 109, 80, 0.06);
  border-radius: 24rpx;
  border: 2rpx solid rgba(139, 109, 80, 0.10);
}

.back-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}

.back-arrow {
  font-size: 32rpx;
  font-weight: 300;
}

/* 当前角色标识 */
.current-role {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-left: auto;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: rgba(255, 243, 224, 0.8);
  padding: 6rpx 16rpx 6rpx 6rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(139, 109, 80, 0.10);
}

.current-role-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(139, 109, 80, 0.15);
}

/* ============ 角色卡片 · 蜡笔手绘风 ============ */
.role-list {
  padding: 0 24rpx;
}

.role-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 3rpx 14rpx rgba(139, 109, 80, 0.08),
    2rpx 2rpx 0 rgba(60, 40, 20, 0.04);
  transition: all 0.3s ease;
  position: relative;
  border: 3rpx solid rgba(60, 40, 20, 0.08);
}

.role-card.selected {
  box-shadow:
    0 6rpx 24rpx rgba(139, 109, 80, 0.14),
    3rpx 3rpx 0 rgba(60, 40, 20, 0.06);
  border-width: 4rpx;
  transform: scale(1.01) rotate(0deg) !important;
}

.role-card:active {
  transform: scale(0.98) !important;
}

/* 选中标记 · 蜡笔圈圈 */
.role-check {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  animation: checkPop 0.3s ease;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.15);
}

@keyframes checkPop {
  0% { transform: scale(0) rotate(-20deg); }
  60% { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

/* 角色头像区 · 蜡笔粗描边 */
.role-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.role-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 5rpx solid;
  overflow: hidden;
  background: #F0EDE8;
  box-shadow: 2rpx 2rpx 0 rgba(60, 40, 20, 0.08);
}

.role-avatar {
  width: 100%;
  height: 100%;
}

/* 角色信息 */
.role-info {
  flex: 1;
  min-width: 0;
}

.role-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.role-name {
  font-size: 32rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-primary);
}

.role-title-badge {
  font-size: 18rpx;
  color: #FFFFFF;
  padding: 5rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  font-weight: 600;
}

.role-personality {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-bottom: 10rpx;
}

.role-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ============ 场景卡片 · 蜡笔手绘风 ============ */
.scene-list {
  padding: 0 24rpx;
}

.scene-card {
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 3rpx 14rpx rgba(139, 109, 80, 0.08),
    2rpx 2rpx 0 rgba(60, 40, 20, 0.04);
  transition: all 0.3s ease;
  position: relative;
  border: 3rpx solid rgba(60, 40, 20, 0.06);
}

.scene-card.selected {
  box-shadow:
    0 6rpx 24rpx rgba(139, 109, 80, 0.14),
    3rpx 3rpx 0 rgba(60, 40, 20, 0.06);
  border-width: 4rpx;
  transform: scale(1.01) rotate(0deg) !important;
}

.scene-card:active {
  transform: scale(0.98) !important;
}

.scene-check {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  animation: checkPop 0.3s ease;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.15);
}

.scene-chapter {
  font-size: 32rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.scene-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  font-style: italic;
}

.scene-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* ============ 深色场景卡片 · 白色文字 ============ */
.scene-card.dark-card {
  border-color: rgba(255, 255, 255, 0.12);
}

.scene-card.dark-card .scene-chapter {
  color: rgba(255, 255, 255, 0.95);
}

.scene-card.dark-card .scene-subtitle {
  color: rgba(255, 255, 255, 0.70);
}

.scene-card.dark-card .scene-desc {
  color: rgba(255, 255, 255, 0.80);
}

.scene-card.dark-card .npc-label {
  color: rgba(255, 255, 255, 0.55);
}

.scene-card.dark-card .npc-tag {
  color: rgba(255, 255, 255, 0.85) !important;
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(255, 255, 255, 0.20) !important;
}

.scene-card.dark-card.selected {
  box-shadow:
    0 6rpx 24rpx rgba(0, 0, 0, 0.30),
    3rpx 3rpx 0 rgba(0, 0, 0, 0.10);
}

.scene-card.dark-card .scene-check {
  border-color: rgba(255, 255, 255, 0.4);
}

/* NPC预览 · 蜡笔涂鸦标签 */
.scene-npcs {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.npc-label {
  font-size: 22rpx;
  color: var(--text-hint);
}

.npc-tag {
  font-size: 22rpx;
  padding: 5rpx 14rpx;
  border: 2rpx solid;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.6);
  font-weight: 600;
}

/* ============ 底部操作区 ============ */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 248, 240, 0.95);
  backdrop-filter: blur(12px);
  box-shadow: 0 -2rpx 16rpx rgba(139, 109, 80, 0.08);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 92rpx;
  border-radius: 46rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  letter-spacing: 3rpx;
  transition: all 0.3s ease;
  border: 3rpx solid rgba(255, 255, 255, 0.15);
  transform: rotate(-0.3deg);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.action-btn.disabled {
  background: #D9D0C4 !important;
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: none;
  transform: none;
}

.action-btn.active:active {
  transform: scale(0.97) rotate(-0.8deg);
  opacity: 0.9;
}

.action-arrow {
  font-size: 40rpx;
  font-weight: 300;
  transition: transform 0.3s ease;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
