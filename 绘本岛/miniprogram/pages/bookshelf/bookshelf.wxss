/* pages/bookshelf/bookshelf.wxss · 蜡笔绘本风 */

.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-top: 100rpx;
  overflow: hidden;
  position: relative;
}

/* ============ 手绘装饰元素 ============ */
.deco-stars {
  position: absolute;
  top: 30rpx;
  right: 32rpx;
  display: flex;
  gap: 12rpx;
}

.deco-star {
  color: var(--crayon-yellow);
  opacity: 0.6;
  animation: starTwinkle 3s ease-in-out infinite;
}

.star1 { font-size: 28rpx; animation-delay: 0s; }
.star2 { font-size: 20rpx; animation-delay: 1s; color: var(--crayon-pink); }
.star3 { font-size: 24rpx; animation-delay: 2s; color: var(--crayon-orange); }

@keyframes starTwinkle {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.2); }
}

/* ============ 顶部标题 ============ */
.header {
  padding: 0 48rpx;
  margin-bottom: 32rpx;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.app-logo {
  font-size: 48rpx;
}

.app-title {
  font-size: 48rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-primary);
  letter-spacing: 4rpx;
  transform: rotate(-1deg);
}

.header-deco {
  font-size: 40rpx;
  color: var(--crayon-pink);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  margin-left: 4rpx;
  transform: rotate(10deg);
  opacity: 0.7;
}

.app-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
  padding-left: 4rpx;
}

.subtitle-underline {
  width: 180rpx;
  height: 4rpx;
  margin-top: 10rpx;
  background: linear-gradient(90deg, var(--crayon-orange), var(--crayon-yellow), transparent);
  border-radius: 4rpx;
  opacity: 0.5;
}

/* ============ 书籍轮播 ============ */
.book-swiper {
  width: 100%;
  height: 980rpx;
}

.swiper-item {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 16rpx 12rpx;
}

/* ============ 书籍卡片 · 蜡笔风 ============ */
.book-card {
  width: 100%;
  background: var(--bg-card);
  border-radius: 40rpx;
  border: 3rpx solid rgba(60, 40, 20, 0.10);
  box-shadow:
    0 6rpx 24rpx rgba(139, 109, 80, 0.10),
    2rpx 2rpx 0 0 rgba(60, 40, 20, 0.04);
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  transform: scale(0.92) rotate(0.3deg);
  opacity: 0.7;
}

.book-card.active {
  transform: scale(1) rotate(0deg);
  opacity: 1;
  box-shadow:
    0 12rpx 48rpx rgba(139, 109, 80, 0.15),
    3rpx 3rpx 0 0 rgba(60, 40, 20, 0.06);
}

.book-card.inactive {
  transform: scale(0.88) rotate(-0.5deg);
  opacity: 0.55;
}

/* ============ 书籍封面 ============ */
.book-cover-wrap {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}

.book-cover {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cover-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

/* 蜡笔纸质纹理覆盖层 */
.cover-texture {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse at 30% 40%, rgba(255, 248, 230, 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 70%, rgba(255, 248, 230, 0.08) 0%, transparent 50%);
  mix-blend-mode: overlay;
  pointer-events: none;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
}

.book-title-on-cover {
  font-size: 40rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 书脊 · 蜡笔涂抹风 */
.book-spine {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 10rpx;
  opacity: 0.75;
  border-radius: 0 4rpx 4rpx 0;
  background-image: linear-gradient(180deg, 
    transparent 0%, 
    currentColor 8%, 
    currentColor 45%, 
    transparent 48%, 
    currentColor 52%, 
    currentColor 92%, 
    transparent 100%
  );
}

/* ============ 书籍信息 ============ */
.book-info {
  padding: 28rpx 32rpx 32rpx;
}

.book-title {
  font-size: 36rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.book-author {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.book-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ============ 预览区域 ============ */
.preview-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

/* 角色预览 */
.character-preview {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.character-avatars {
  display: flex;
  align-items: center;
}

.mini-avatar-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid var(--bg-card);
  box-shadow: 0 2rpx 6rpx rgba(139, 109, 80, 0.12);
  overflow: hidden;
  position: relative;
  background: #F0EDE8;
}

.mini-avatar {
  width: 100%;
  height: 100%;
}

.character-count {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 剧情章节数 */
.scene-count {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.scene-count-icon {
  font-size: 24rpx;
}

/* ============ 开始按钮 · 蜡笔填充风 ============ */
.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 84rpx;
  border-radius: 42rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  letter-spacing: 3rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.15);
  transform: rotate(-0.3deg);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.start-btn:active {
  transform: scale(0.96) rotate(-1deg);
  opacity: 0.9;
}

.btn-arrow {
  font-size: 40rpx;
  font-weight: 300;
  transition: transform 0.3s ease;
}

.start-btn:active .btn-arrow {
  transform: translateX(8rpx);
}

/* ============ 指示器 · 蜡笔涂鸦风 ============ */
.indicator-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 18rpx;
  margin-top: 20rpx;
}

.indicator-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #D9D0C4;
  transition: all 0.4s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(60, 40, 20, 0.08);
}

.indicator-dot.active {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.indicator-star {
  font-size: 18rpx;
  color: #FFFFFF;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* ============ 底部提示 · 手绘风 ============ */
.bottom-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
  padding-bottom: 40rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}

.tip-arrow-left,
.tip-arrow-right {
  font-size: 36rpx;
  color: var(--crayon-orange);
  opacity: 0.5;
  font-weight: 300;
  animation: arrowBounce 2s ease-in-out infinite;
}

.tip-arrow-right {
  animation-delay: 0.3s;
}

@keyframes arrowBounce {
  0%, 100% { transform: translateX(0); opacity: 0.4; }
  50% { transform: translateX(4rpx); opacity: 0.7; }
}

.tip-arrow-left {
  animation-name: arrowBounceLeft;
}

@keyframes arrowBounceLeft {
  0%, 100% { transform: translateX(0); opacity: 0.4; }
  50% { transform: translateX(-4rpx); opacity: 0.7; }
}

.tip-text {
  font-size: 24rpx;
  letter-spacing: 1rpx;
}
